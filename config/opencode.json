{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "architect": {
      "description": "Plan & design - system architecture, data models, tech stack",
      "prompt": "{file:./agents/dev-team/architect.md}",
      "mode": "primary"
    },
    "researcher": {
      "description": "Research - evaluate tools, frameworks, best practices",
      "prompt": "{file:./agents/dev-team/researcher.md}",
      "mode": "primary"
    },
    "master-dev": {
      "description": "Build anything - universal developer for any tech",
      "prompt": "{file:./agents/master-dev.md}",
      "mode": "primary"
    },
    "orchestrator": {
      "description": "Coordinate - manages the dev team, your main contact",
      "prompt": "{file:./agents/dev-team/orchestrator.md}",
      "mode": "primary"
    },
    "frontend-dev": {
      "description": "UI/Frontend - React, components, styling",
      "prompt": "{file:./agents/dev-team/frontend-dev.md}",
      "mode": "all"
    },
    "backend-dev": {
      "description": "Backend - APIs, databases, auth",
      "prompt": "{file:./agents/dev-team/backend-dev.md}",
      "mode": "all"
    },
    "devops": {
      "description": "DevOps - CI/CD, Docker, deployment",
      "prompt": "{file:./agents/dev-team/devops.md}",
      "mode": "all"
    },
    "qa-tester": {
      "description": "QA/Testing - tests, quality, bugs",
      "prompt": "{file:./agents/dev-team/qa-tester.md}",
      "mode": "all"
    },
    "security-dev": {
      "description": "Security - audits, vulnerabilities, compliance",
      "prompt": "{file:./agents/dev-team/security-dev.md}",
      "mode": "all"
    },
    "docs-writer": {
      "description": "Docs - README, API docs, tutorials",
      "prompt": "{file:./agents/dev-team/docs-writer.md}",
      "mode": "all"
    }
  }
}
